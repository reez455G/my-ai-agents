#!/usr/bin/env bash
# Runs after every commit. If knowledge/ changed in this commit, regenerate
# embedded-class .omp/skills/ entries (sync-okf-skills.py) and push any drift,
# so knowledge/skills|agent-rules edits propagate without a manual
# ./sync-skills.sh run. Bare-class knowledge files still need manual
# synthesis (see skill://okf-to-native-skill-migration) — sync-skills.sh
# prints a WARN for those, it does not silently drop them.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
git diff-tree --no-commit-id --name-only -r HEAD | grep -q '^knowledge/' || exit 0
[ -x ./sync-skills.sh ] && ./sync-skills.sh || true
