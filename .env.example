# LLM Provider untuk Hindsight (Ollama lokal — tidak perlu API key)
HINDSIGHT_API_LLM_PROVIDER=ollama
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_BASE_URL=http://host.docker.internal:11434
HINDSIGHT_API_LLM_MODEL=gpt-oss:120b

# Endpoint Hindsight API yang dipakai kode Python kamu
HINDSIGHT_API_URL=http://localhost:8890

# Worker identity stabil, wajib untuk deployment 24/7
HINDSIGHT_API_WORKER_ID=hindsight-prod

# Token autentikasi Hindsight API (wajib untuk akses lintas device via Tailscale)
# Generate dengan: openssl rand -hex 32
HINDSIGHT_API_TOKEN=ganti-dengan-token-rahasia-yang-panjang

# Bank memori utama (samakan di semua device dan dengan HINDSIGHT_BANK_ID
# di bawah — satu bank yang sama dipakai lintas otak/device)
AGENT_BANK_ID=my-ai-agent
# Bank memori omp (dipakai omp-config.template.yml); biasanya = AGENT_BANK_ID
HINDSIGHT_BANK_ID=my-ai-agent
# Kalibrasi recall: low=tercepat, mid=seimbang, high=terdalam
HINDSIGHT_RECALL_BUDGET=mid
HINDSIGHT_RECALL_MAX_TOKENS=2048
